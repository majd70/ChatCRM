@inject Microsoft.AspNetCore.Identity.UserManager<User> UserManager

@{
    User? currentUser = null;
    var navDisplayName = User.Identity?.Name ?? "Account";
    string? navImagePath = null;
    var navInitials = "U";

    if (User.Identity?.IsAuthenticated == true)
    {
        currentUser = await UserManager.GetUserAsync(User);
        if (currentUser is not null)
        {
            var fullName = string.Join(" ", new[] { currentUser.FirstName, currentUser.LastName }.Where(x => !string.IsNullOrWhiteSpace(x)));
            navDisplayName = string.IsNullOrWhiteSpace(fullName) ? (currentUser.Email ?? currentUser.UserName ?? "Account") : fullName;
            navImagePath = currentUser.ProfileImagePath;

            var initialsSource = !string.IsNullOrWhiteSpace(fullName) ? fullName : (currentUser.Email ?? "U");
            navInitials = string.Concat(
                initialsSource
                    .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                    .Take(2)
                    .Select(part => char.ToUpperInvariant(part[0])));

            if (string.IsNullOrWhiteSpace(navInitials))
            {
                navInitials = "U";
            }
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChatCRM</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ChatCRM.MVC.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="site-header">
            <nav class="navbar navbar-expand-lg">
                <div class="container">
                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">ChatCRM</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div id="mainNav" class="collapse navbar-collapse">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item">
                                    <a class="nav-link has-icon" href="/dashboard/chats">
                                        @await Html.PartialAsync("_Icon", new IconModel("message-square", size: 16))
                                        <span>Chats</span>
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            </li>
                        </ul>
                        <div class="d-flex align-items-center gap-2 ms-lg-3">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a asp-controller="Account" asp-action="Profile" class="profile-chip">
                                    @if (!string.IsNullOrWhiteSpace(navImagePath))
                                    {
                                        <img src="@navImagePath" alt="@navDisplayName" class="profile-chip-avatar" />
                                    }
                                    else
                                    {
                                        <span class="profile-chip-avatar profile-chip-avatar-fallback">@navInitials</span>
                                    }
                                    <span class="profile-chip-copy">
                                        <strong>@navDisplayName</strong>
                                        <span>Manage profile</span>
                                    </span>
                                </a>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-light btn-sm">Sign out</button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Sign in</a>
                                <a class="btn btn-accent btn-sm" asp-controller="Account" asp-action="Register">Create account</a>
                            }
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main class="page-content">
            <div class="container">
                @{
                    var statusMessage = TempData["StatusMessage"] as string;
                    var statusType = TempData["StatusType"] as string ?? "info";
                }

                @if (!string.IsNullOrWhiteSpace(statusMessage))
                {
                    <div class="alert alert-@statusType auth-alert" role="alert">
                        @statusMessage
                    </div>
                }

                @RenderBody()
            </div>
        </main>

        <footer class="site-footer">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <span>&copy; 2026 ChatCRM</span>
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
