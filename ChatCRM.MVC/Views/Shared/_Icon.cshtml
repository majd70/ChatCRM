@*
    Single-source-of-truth icon helper. Inline SVGs sourced from Lucide (lucide.dev) — MIT licensed.
    All icons share the same viewBox, stroke-width, and inherit color via `currentColor`,
    so a parent's CSS color/font-size cascade controls them.

    Usage:
        @await Html.PartialAsync("_Icon", new IconModel("trash"))
        @await Html.PartialAsync("_Icon", new IconModel("send", size: 18, cssClass: "icon-spin"))
        @await Html.PartialAsync("_Icon", new IconModel("check", ariaLabel: "Done"))

    To add a new icon, append a new `case` below with the SVG path data.
*@
@model ChatCRM.MVC.Models.IconModel

@{
    var size = Model.Size > 0 ? Model.Size : 18;
    var cssClass = string.IsNullOrWhiteSpace(Model.CssClass) ? "icon" : $"icon {Model.CssClass}";
    var ariaAttrs = string.IsNullOrWhiteSpace(Model.AriaLabel)
        ? "aria-hidden=\"true\" focusable=\"false\""
        : $"role=\"img\" aria-label=\"{Model.AriaLabel}\"";

    // Lucide stroke-based icons. All use viewBox 0 0 24 24, stroke-width 2.
    string body = Model.Name switch
    {
        // Navigation / brand
        "message-square" => "<path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/>",
        "smartphone"     => "<rect x=\"5\" y=\"2\" width=\"14\" height=\"20\" rx=\"2\" ry=\"2\"/><line x1=\"12\" y1=\"18\" x2=\"12.01\" y2=\"18\"/>",
        "user"           => "<path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/>",
        "log-out"        => "<path d=\"M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4\"/><polyline points=\"16 17 21 12 16 7\"/><line x1=\"21\" y1=\"12\" x2=\"9\" y2=\"12\"/>",

        // Actions
        "plus"           => "<line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/>",
        "send"           => "<line x1=\"22\" y1=\"2\" x2=\"11\" y2=\"13\"/><polygon points=\"22 2 15 22 11 13 2 9 22 2\"/>",
        "search"         => "<circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/>",
        "trash"          => "<polyline points=\"3 6 5 6 21 6\"/><path d=\"M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6\"/><line x1=\"10\" y1=\"11\" x2=\"10\" y2=\"17\"/><line x1=\"14\" y1=\"11\" x2=\"14\" y2=\"17\"/><path d=\"M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2\"/>",
        "qr-code"        => "<rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/><line x1=\"14\" y1=\"14\" x2=\"14\" y2=\"21\"/><line x1=\"21\" y1=\"14\" x2=\"21\" y2=\"21\"/><line x1=\"17.5\" y1=\"14\" x2=\"17.5\" y2=\"21\"/><line x1=\"14\" y1=\"17.5\" x2=\"21\" y2=\"17.5\"/>",
        "refresh-cw"     => "<polyline points=\"23 4 23 10 17 10\"/><polyline points=\"1 20 1 14 7 14\"/><path d=\"M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15\"/>",
        "settings"       => "<circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z\"/>",

        // Feedback
        "check"          => "<polyline points=\"20 6 9 17 4 12\"/>",
        "check-double"   => "<polyline points=\"7 11 11 15 17 9\"/><polyline points=\"13 11 17 15 23 9\"/>",
        "x"              => "<line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"18\" x2=\"18\" y2=\"6\"/>",
        "chevron-down"   => "<polyline points=\"6 9 12 15 18 9\"/>",
        "inbox"          => "<polyline points=\"22 12 16 12 14 15 10 15 8 12 2 12\"/><path d=\"M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z\"/>",
        "lock"           => "<rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"/><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"/>",
        "users"          => "<path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/>",
        "more-vertical"  => "<circle cx=\"12\" cy=\"12\" r=\"1\"/><circle cx=\"12\" cy=\"5\" r=\"1\"/><circle cx=\"12\" cy=\"19\" r=\"1\"/>",
        "eye"            => "<path d=\"M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/>",
        "download"       => "<path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"/><polyline points=\"7 10 12 15 17 10\"/><line x1=\"12\" y1=\"15\" x2=\"12\" y2=\"3\"/>",
        "shield-off"     => "<path d=\"M19.69 14a6.9 6.9 0 0 0 .31-2V5l-8-3-3.16 1.18\"/><path d=\"M4.73 4.73L4 5v7c0 6 8 10 8 10a20.29 20.29 0 0 0 5.62-4.38\"/><line x1=\"1\" y1=\"1\" x2=\"23\" y2=\"23\"/>",
        "filter"         => "<polygon points=\"22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3\"/>",
        "shield"         => "<path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/>",
        "briefcase"      => "<rect x=\"2\" y=\"7\" width=\"20\" height=\"14\" rx=\"2\"/><path d=\"M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2\"/>",
        "headset"        => "<path d=\"M3 18v-6a9 9 0 0 1 18 0v6\"/><path d=\"M21 19a2 2 0 0 1-2 2h-1v-7h3z\"/><path d=\"M3 19a2 2 0 0 0 2 2h1v-7H3z\"/>",
        "arrow-up-down"  => "<polyline points=\"7 10 12 5 17 10\"/><polyline points=\"7 14 12 19 17 14\"/>",
        _                => string.Empty
    };

    // Brand-style icons rendered with FILL instead of stroke. Same viewBox.
    bool isFill = false;
    string brandBody = Model.Name switch
    {
        "channel-whatsapp"  => "<path d=\"M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.88 11.93L4 20l4.18-1.1a7.93 7.93 0 0 0 3.86 1h.01a7.94 7.94 0 0 0 7.95-7.93 7.88 7.88 0 0 0-2.4-5.65zM12.05 18.55h-.01a6.6 6.6 0 0 1-3.36-.92l-.24-.14-2.5.65.67-2.43-.16-.25a6.59 6.59 0 1 1 12.23-3.5 6.6 6.6 0 0 1-6.63 6.59zm3.62-4.93c-.2-.1-1.18-.58-1.36-.65-.18-.07-.31-.1-.45.1-.13.2-.51.65-.62.78-.12.13-.23.15-.42.05-.2-.1-.84-.31-1.6-.99a6 6 0 0 1-1.1-1.38c-.12-.2-.01-.3.09-.4.1-.09.2-.23.3-.35.1-.12.13-.2.2-.34.07-.13.03-.25-.02-.35-.05-.1-.45-1.08-.62-1.48-.16-.39-.33-.34-.45-.34l-.39-.01a.74.74 0 0 0-.54.25 2.27 2.27 0 0 0-.7 1.68c0 .99.71 1.95.82 2.08.1.13 1.41 2.16 3.43 3.03.48.2.85.33 1.14.42.48.15.92.13 1.27.08.39-.06 1.18-.48 1.35-.95.17-.46.17-.86.12-.94-.06-.08-.18-.13-.38-.23z\"/>",
        "channel-instagram" => "<path d=\"M12 2.16c3.2 0 3.58 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38c-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.71 3.71 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.43-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 2.13c-3.16 0-3.51 0-4.76.07-1.07.05-1.65.23-2.04.39a3.4 3.4 0 0 0-1.27.83 3.4 3.4 0 0 0-.83 1.27c-.16.39-.34.97-.39 2.04-.07 1.25-.07 1.6-.07 4.76s0 3.51.07 4.76c.05 1.07.23 1.65.39 2.04.21.56.46.95.83 1.27.32.37.71.62 1.27.83.39.16.97.34 2.04.39 1.25.07 1.6.07 4.76.07s3.51 0 4.76-.07c1.07-.05 1.65-.23 2.04-.39a3.4 3.4 0 0 0 1.27-.83 3.4 3.4 0 0 0 .83-1.27c.16-.39.34-.97.39-2.04.07-1.25.07-1.6.07-4.76s0-3.51-.07-4.76c-.05-1.07-.23-1.65-.39-2.04a3.4 3.4 0 0 0-.83-1.27 3.4 3.4 0 0 0-1.27-.83c-.39-.16-.97-.34-2.04-.39C15.51 4.3 15.16 4.29 12 4.29zm0 3.63a4.08 4.08 0 1 0 0 8.16 4.08 4.08 0 0 0 0-8.16zm0 6.73a2.65 2.65 0 1 1 0-5.3 2.65 2.65 0 0 1 0 5.3zm5.19-6.89a.95.95 0 1 1-1.91 0 .95.95 0 0 1 1.91 0z\"/>",
        "channel-messenger" => "<path d=\"M12 2C6.36 2 2 6.13 2 11.7c0 2.91 1.19 5.44 3.14 7.18.16.14.27.34.27.56v3.16c0 .25.27.4.49.27l3.42-2.07a.65.65 0 0 1 .55-.07 11 11 0 0 0 2.13.21c5.64 0 10-4.13 10-9.7C22 6.13 17.64 2 12 2zm6.04 7.15-2.93 4.66a1.5 1.5 0 0 1-2.16.4l-2.33-1.75a.6.6 0 0 0-.72 0l-3.15 2.4c-.42.32-.97-.18-.69-.62l2.94-4.66a1.5 1.5 0 0 1 2.16-.4l2.33 1.75a.6.6 0 0 0 .72 0l3.15-2.4c.42-.32.97.18.68.62z\"/>",
        _ => string.Empty
    };

    if (!string.IsNullOrEmpty(brandBody))
    {
        body = brandBody;
        isFill = true;
    }
}

@if (!string.IsNullOrEmpty(body))
{
    @if (isFill)
    {
        <svg xmlns="http://www.w3.org/2000/svg"
             class="@cssClass"
             width="@size" height="@size"
             viewBox="0 0 24 24"
             fill="currentColor"
             @Html.Raw(ariaAttrs)>
            @Html.Raw(body)
        </svg>
    }
    else
    {
        <svg xmlns="http://www.w3.org/2000/svg"
             class="@cssClass"
             width="@size" height="@size"
             viewBox="0 0 24 24"
             fill="none"
             stroke="currentColor"
             stroke-width="2"
             stroke-linecap="round"
             stroke-linejoin="round"
             @Html.Raw(ariaAttrs)>
            @Html.Raw(body)
        </svg>
    }
}
