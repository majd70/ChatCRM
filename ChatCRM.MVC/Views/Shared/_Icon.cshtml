@*
    Single-source-of-truth icon helper. Inline SVGs sourced from Lucide (lucide.dev) — MIT licensed.
    All icons share the same viewBox, stroke-width, and inherit color via `currentColor`,
    so a parent's CSS color/font-size cascade controls them.

    Usage:
        @await Html.PartialAsync("_Icon", new IconModel("trash"))
        @await Html.PartialAsync("_Icon", new IconModel("send", size: 18, cssClass: "icon-spin"))
        @await Html.PartialAsync("_Icon", new IconModel("check", ariaLabel: "Done"))

    To add a new icon, append a new `case` below with the SVG path data.
*@
@model ChatCRM.MVC.Models.IconModel

@{
    var size = Model.Size > 0 ? Model.Size : 18;
    var cssClass = string.IsNullOrWhiteSpace(Model.CssClass) ? "icon" : $"icon {Model.CssClass}";
    var ariaAttrs = string.IsNullOrWhiteSpace(Model.AriaLabel)
        ? "aria-hidden=\"true\" focusable=\"false\""
        : $"role=\"img\" aria-label=\"{Model.AriaLabel}\"";

    // Lucide stroke-based icons. All use viewBox 0 0 24 24, stroke-width 2.
    string body = Model.Name switch
    {
        // Navigation / brand
        "message-square" => "<path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/>",
        "smartphone"     => "<rect x=\"5\" y=\"2\" width=\"14\" height=\"20\" rx=\"2\" ry=\"2\"/><line x1=\"12\" y1=\"18\" x2=\"12.01\" y2=\"18\"/>",
        "user"           => "<path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/>",
        "log-out"        => "<path d=\"M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4\"/><polyline points=\"16 17 21 12 16 7\"/><line x1=\"21\" y1=\"12\" x2=\"9\" y2=\"12\"/>",

        // Actions
        "plus"           => "<line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/>",
        "send"           => "<line x1=\"22\" y1=\"2\" x2=\"11\" y2=\"13\"/><polygon points=\"22 2 15 22 11 13 2 9 22 2\"/>",
        "search"         => "<circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/>",
        "trash"          => "<polyline points=\"3 6 5 6 21 6\"/><path d=\"M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6\"/><line x1=\"10\" y1=\"11\" x2=\"10\" y2=\"17\"/><line x1=\"14\" y1=\"11\" x2=\"14\" y2=\"17\"/><path d=\"M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2\"/>",
        "qr-code"        => "<rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/><line x1=\"14\" y1=\"14\" x2=\"14\" y2=\"21\"/><line x1=\"21\" y1=\"14\" x2=\"21\" y2=\"21\"/><line x1=\"17.5\" y1=\"14\" x2=\"17.5\" y2=\"21\"/><line x1=\"14\" y1=\"17.5\" x2=\"21\" y2=\"17.5\"/>",
        "refresh-cw"     => "<polyline points=\"23 4 23 10 17 10\"/><polyline points=\"1 20 1 14 7 14\"/><path d=\"M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15\"/>",
        "settings"       => "<circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z\"/>",

        // Feedback
        "check"          => "<polyline points=\"20 6 9 17 4 12\"/>",
        "check-double"   => "<polyline points=\"7 11 11 15 17 9\"/><polyline points=\"13 11 17 15 23 9\"/>",
        "x"              => "<line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"18\" x2=\"18\" y2=\"6\"/>",
        "chevron-down"   => "<polyline points=\"6 9 12 15 18 9\"/>",
        _                => string.Empty
    };
}

@if (!string.IsNullOrEmpty(body))
{
    <svg xmlns="http://www.w3.org/2000/svg"
         class="@cssClass"
         width="@size" height="@size"
         viewBox="0 0 24 24"
         fill="none"
         stroke="currentColor"
         stroke-width="2"
         stroke-linecap="round"
         stroke-linejoin="round"
         @Html.Raw(ariaAttrs)>
        @Html.Raw(body)
    </svg>
}
