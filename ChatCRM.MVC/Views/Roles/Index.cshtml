@using System.Globalization
@inject Microsoft.Extensions.Localization.IStringLocalizer T
@inject ChatCRM.MVC.Localization.JsonStringLocalizer.ResourceCache LocalizationCache
@{
    ViewData["Title"] = T["Roles.Title"].Value + " — " + T["SettingsNav.Title"].Value;
    Layout = null;
    var groups = (Dictionary<string, string[]>)ViewBag.Groups;
    var labels = (Dictionary<string, string>)ViewBag.Labels;
    var activeRoles = (List<string>)ViewBag.ActiveRoles ?? new();

    var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var translations = LocalizationCache.Load(culture) ?? LocalizationCache.Load("en") ?? new Dictionary<string, string>();
    var translationsJson = System.Text.Json.JsonSerializer.Serialize(translations);
    var htmlLang = culture;
    var htmlDir = (culture is "ar" or "he" or "fa" or "ur") ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@htmlLang" dir="@htmlDir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@T["Roles.Title"] — ChatCRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/instances.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/inbox.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/settings.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/users.css" asp-append-version="true" />
    <script>
        window.__i18n__ = @Html.Raw(translationsJson);
        window.__i18nCulture__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(culture));
    </script>
    <script src="~/js/i18n.js" asp-append-version="true"></script>
</head>
<body class="inbox-shell">

@await Html.PartialAsync("_DashboardRail", "settings")

<div class="settings-layout">
    @await Html.PartialAsync("_SettingsSidenav", "roles")

    <main class="settings-main">
        <div class="settings-header">
            <div>
                <h1 class="settings-title">@T["Roles.Title"]</h1>
                <p class="settings-sub">@T["Roles.Subtitle"]</p>
            </div>
            <button class="btn-primary-soft has-icon" id="addRoleBtn" type="button">
                @await Html.PartialAsync("_Icon", new IconModel("plus", size: 14))
                <span>@T["Roles.AddRole"]</span>
            </button>
        </div>

        @* ─── Toolbar: search + filter + sort ────────────────────────── *@
        <section class="roles-toolbar" role="toolbar" aria-label="@T["Roles.Toolbar.Aria"]">
            <div class="filter-search" style="max-width:340px;">
                @await Html.PartialAsync("_Icon", new IconModel("search", size: 14, cssClass: "filter-search-icon"))
                <input type="search" id="roleSearch" placeholder="@T["Roles.SearchPlaceholder"]" aria-label="@T["Roles.SearchAria"]" />
            </div>

            <div class="roles-filter-tabs" role="tablist" aria-label="@T["Roles.Filter.Aria"]">
                <button class="rt-chip is-active" data-filter="all"     type="button" role="tab" aria-selected="true">@T["Roles.Filter.All"]</button>
                <button class="rt-chip"           data-filter="builtin" type="button" role="tab" aria-selected="false">@T["Roles.Filter.Builtin"]</button>
                <button class="rt-chip"           data-filter="custom"  type="button" role="tab" aria-selected="false">@T["Roles.Filter.Custom"]</button>
            </div>

            <label class="rt-sort">
                <span class="rt-sort-label">@T["Roles.Sort.Label"]</span>
                <select id="roleSort" aria-label="@T["Roles.Sort.Aria"]">
                    <option value="name-asc">@T["Roles.Sort.NameAsc"]</option>
                    <option value="name-desc">@T["Roles.Sort.NameDesc"]</option>
                    <option value="users-desc">@T["Roles.Sort.UsersDesc"]</option>
                    <option value="users-asc">@T["Roles.Sort.UsersAsc"]</option>
                    <option value="perms-desc">@T["Roles.Sort.PermsDesc"]</option>
                    <option value="perms-asc">@T["Roles.Sort.PermsAsc"]</option>
                </select>
            </label>
        </section>

        @* ─── Role cards container ─── *@
        <section class="roles-list" id="rolesList" aria-live="polite">
            <div class="contacts-empty">@T["Action.Loading"]</div>
        </section>
    </main>
</div>

@* ─── Role modal ─── *@
<div class="modal-backdrop d-none" id="roleModal" onclick="if(event.target===this) closeRoleModal()">
    <div class="modal-panel modal-panel-wide" role="dialog" aria-labelledby="roleModalTitle" aria-modal="true">
        <div class="modal-header">
            <h3 id="roleModalTitle">@T["Roles.Modal.EditTitle"]</h3>
            <button class="modal-close" type="button" onclick="closeRoleModal()" aria-label="@T["Action.Close"]">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-error d-none" id="roleFormError" role="alert"></div>

            <label class="form-field">
                <span>@T["Roles.Field.Name"] <em>*</em></span>
                <input type="text" id="roleName" class="form-input" maxlength="50" />
                <small class="form-hint" id="roleNameHint"></small>
            </label>

            <div class="permissions-grid">
                @foreach (var (groupName, perms) in groups)
                {
                    <div class="permission-group" data-group="@groupName">
                        <div class="permission-group-head">
                            <h4>@groupName</h4>
                            <button type="button" class="link-btn" data-toggle-group="@groupName">@T["Roles.ToggleAll"]</button>
                        </div>
                        <div class="permission-list">
                            @foreach (var p in perms)
                            {
                                var lbl = labels.TryGetValue(p, out var l) ? l : p;
                                <label class="permission-row">
                                    <input type="checkbox" data-permission="@p" data-group="@groupName" />
                                    <div>
                                        <div class="permission-label">@lbl</div>
                                        <div class="permission-key" title="@p">@p</div>
                                    </div>
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="modal-actions">
            <button class="btn-ghost" type="button" onclick="closeRoleModal()">@T["Action.Cancel"]</button>
            <button class="btn-primary-round" type="button" id="roleSaveBtn">
                <span class="btn-label">@T["Action.Save"]</span>
                <span class="btn-spinner d-none" aria-hidden="true"></span>
            </button>
        </div>
    </div>
</div>

@* ─── Confirm modal ─── *@
<div class="modal-backdrop d-none" id="confirmModal" onclick="if(event.target===this) closeConfirmModal()">
    <div class="modal-panel modal-panel-small" role="dialog" aria-labelledby="confirmTitle" aria-modal="true">
        <div class="modal-header">
            <h3 id="confirmTitle">@T["Common.Confirm.Title"]</h3>
            <button class="modal-close" type="button" onclick="closeConfirmModal()" aria-label="@T["Action.Close"]">✕</button>
        </div>
        <div class="modal-body">
            <p id="confirmBody" style="margin:0;font-size:13.5px;color:#374151;"></p>
        </div>
        <div class="modal-actions">
            <button class="btn-ghost" type="button" onclick="closeConfirmModal()">@T["Action.Cancel"]</button>
            <button class="btn-ghost btn-danger" type="button" id="confirmAction">@T["Common.Confirm.Action"]</button>
        </div>
    </div>
</div>

<div class="toast-stack" id="toastStack"></div>
@Html.AntiForgeryToken()

<script>
    window.__PERMISSION_LABELS__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(labels));
    window.__PERMISSION_GROUPS__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(groups));
    window.__ACTIVE_ROLES__      = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(activeRoles));
</script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/roles.js" asp-append-version="true"></script>

</body>
</html>
