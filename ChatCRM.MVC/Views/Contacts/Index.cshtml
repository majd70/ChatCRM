@using System.Globalization
@inject Microsoft.Extensions.Localization.IStringLocalizer T
@inject ChatCRM.MVC.Localization.JsonStringLocalizer.ResourceCache LocalizationCache
@{
    ViewData["Title"] = T["Contacts.Title"].Value;
    Layout = null;
    var team = (List<ChatCRM.Application.Chats.DTOs.TeamMemberDto>)ViewBag.TeamMembers;
    var currentUserId = (string?)ViewBag.CurrentUserId;

    var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var translations = LocalizationCache.Load(culture) ?? LocalizationCache.Load("en") ?? new Dictionary<string, string>();
    var translationsJson = System.Text.Json.JsonSerializer.Serialize(translations);
    var htmlLang = culture;
    var htmlDir = (culture is "ar" or "he" or "fa" or "ur") ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@htmlLang" dir="@htmlDir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@T["Contacts.Title"] — ChatCRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/instances.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/inbox.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/contacts.css" asp-append-version="true" />
    <script>
        window.__i18n__ = @Html.Raw(translationsJson);
        window.__i18nCulture__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(culture));
    </script>
    <script src="~/js/i18n.js" asp-append-version="true"></script>
</head>
<body class="inbox-shell">

@await Html.PartialAsync("_DashboardRail", "contacts")

<main class="contacts-page">

    <header class="contacts-header">
        <div>
            <h1 class="contacts-title">@T["Contacts.Title"]</h1>
            <p class="contacts-sub">@T["Contacts.Subtitle"]</p>
        </div>
        <div class="contacts-toolbar">
            <button class="btn-primary-soft has-icon" id="exportBtn" type="button">
                @await Html.PartialAsync("_Icon", new IconModel("download", size: 14))
                <span class="export-label">@T["Contacts.Export"]</span>
                <span class="btn-spinner d-none" aria-hidden="true"></span>
            </button>
        </div>
    </header>

    <section class="contacts-filters">
        <div class="filter-search">
            @await Html.PartialAsync("_Icon", new IconModel("search", size: 14, cssClass: "filter-search-icon"))
            <input type="search" id="searchInput" placeholder="@T["Contacts.SearchPlaceholder"]" />
        </div>

        <select id="lifecycleFilter" class="filter-select" aria-label="@T["Contacts.Filter.Lifecycle"]">
            <option value="">@T["Contacts.Filter.AllLifecycles"]</option>
            <option value="0">@T["Lifecycle.NewClient"]</option>
            <option value="1">@T["Lifecycle.NotResponding"]</option>
            <option value="2">@T["Lifecycle.Interested"]</option>
            <option value="3">@T["Lifecycle.Thinking"]</option>
            <option value="4">@T["Lifecycle.WantsAMeeting"]</option>
            <option value="5">@T["Lifecycle.WaitingForMeeting"]</option>
            <option value="6">@T["Lifecycle.Discussed"]</option>
            <option value="7">@T["Lifecycle.PotentialClient"]</option>
            <option value="8">@T["Lifecycle.WillMakePayment"]</option>
            <option value="9">@T["Lifecycle.WaitingForContract"]</option>
            <option value="10">@T["Lifecycle.OurClient"]</option>
        </select>

        <select id="assigneeFilter" class="filter-select" aria-label="@T["Contacts.Filter.Assignee"]">
            <option value="">@T["Contacts.Filter.AllAssignees"]</option>
            @foreach (var u in team)
            {
                <option value="@u.Id">@u.Name</option>
            }
        </select>

        <select id="statusFilter" class="filter-select" aria-label="@T["Contacts.Filter.Status"]">
            <option value="">@T["Contacts.Filter.AllStatuses"]</option>
            <option value="0">@T["Inbox.Open"]</option>
            <option value="2">@T["Inbox.Closed"]</option>
        </select>

        <select id="blockedFilter" class="filter-select" aria-label="@T["Contacts.Filter.Blocked"]">
            <option value="">@T["Contacts.Filter.ActiveAndBlocked"]</option>
            <option value="false">@T["Contacts.Filter.ActiveOnly"]</option>
            <option value="true">@T["Contacts.Filter.BlockedOnly"]</option>
        </select>
    </section>

    <section class="contacts-table-wrap">
        <table class="contacts-table" id="contactsTable">
            <thead>
                <tr>
                    <th class="col-name sortable" data-sort="name">@T["Contacts.Column.Contact"]</th>
                    <th class="col-channel">@T["Contacts.Column.Channel"]</th>
                    <th class="col-last sortable" data-sort="lastMessage">@T["Contacts.Column.LastMessage"]</th>
                    <th class="col-created sortable" data-sort="createdAt">@T["Contacts.Column.Created"]</th>
                    <th class="col-country">@T["Contacts.Column.Country"]</th>
                    <th class="col-language">@T["Contacts.Column.Language"]</th>
                    <th class="col-lifecycle">@T["Contacts.Column.Lifecycle"]</th>
                    <th class="col-assigned">@T["Contacts.Column.AssignedTo"]</th>
                    <th class="col-status">@T["Contacts.Column.Status"]</th>
                    <th class="col-actions"></th>
                </tr>
            </thead>
            <tbody id="contactsBody">
                <tr><td colspan="10" class="contacts-empty">@T["Action.Loading"]</td></tr>
            </tbody>
        </table>
    </section>

    <footer class="contacts-pagination">
        <div class="pagination-left">
            <span class="pagination-info" id="pageInfo">—</span>
            <label class="page-size-picker">
                @T["Contacts.RowsPerPage"]
                <select id="pageSize">
                    <option value="10">10</option>
                    <option value="25" selected>25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </label>
        </div>
        <div class="pagination-controls">
            <button id="prevPage" class="btn-ghost" type="button">@T["Contacts.Pagination.Previous"]</button>
            <span id="pageLabel" class="pagination-page">—</span>
            <button id="nextPage" class="btn-ghost" type="button">@T["Contacts.Pagination.Next"]</button>
        </div>
    </footer>
</main>

@* ─── Contact Details modal ─── *@
<div class="modal-backdrop d-none" id="contactDetailsModal" onclick="if(event.target===this) closeContactDetailsModal()">
    <div class="modal-panel modal-panel-detail">
        <div class="modal-header">
            <h3>@T["Contacts.Modal.Title"]</h3>
            <button class="modal-close" type="button" onclick="closeContactDetailsModal()">✕</button>
        </div>
        <div class="modal-body cd-body">
            <div class="cd-loading" id="cdLoading">@T["Action.Loading"]</div>

            <div class="cd-content d-none" id="cdContent">
                <div class="cd-hero">
                    <div class="cd-avatar" id="cdAvatar">?</div>
                    <div class="cd-name" id="cdName">—</div>
                    <div class="cd-phone" id="cdPhone">—</div>
                </div>

                <dl class="cd-grid">
                    <div class="cd-row">
                        <dt>@T["Contacts.Column.Lifecycle"]</dt>
                        <dd id="cdLifecycle"><span class="badge-btn lc-gray"><span class="badge-dot"></span>—</span></dd>
                    </div>
                    <div class="cd-row">
                        <dt>@T["Contacts.Column.Channel"]</dt>
                        <dd id="cdChannel">—</dd>
                    </div>
                    <div class="cd-row">
                        <dt>@T["Contacts.Column.Country"]</dt>
                        <dd id="cdCountry">—</dd>
                    </div>
                    <div class="cd-row">
                        <dt>@T["Contacts.Column.Language"]</dt>
                        <dd id="cdLanguage">—</dd>
                    </div>
                    <div class="cd-row">
                        <dt>@T["Contacts.Column.AssignedTo"]</dt>
                        <dd id="cdAssigned">@T["Inbox.Unassigned"]</dd>
                    </div>
                    <div class="cd-row">
                        <dt>@T["Contacts.Column.Status"]</dt>
                        <dd id="cdStatus"><span class="badge-btn status-badge status-open"><span class="status-dot-inline"></span>@T["Inbox.Open"]</span></dd>
                    </div>
                    <div class="cd-row">
                        <dt>@T["Contacts.Blocked"]</dt>
                        <dd id="cdBlocked">@T["Contacts.NotBlocked"]</dd>
                    </div>
                    <div class="cd-row">
                        <dt>@T["Contacts.FirstContact"]</dt>
                        <dd id="cdCreated">—</dd>
                    </div>
                    <div class="cd-row">
                        <dt>@T["Contacts.TotalMessages"]</dt>
                        <dd id="cdMsgCount">0</dd>
                    </div>
                    <div class="cd-row">
                        <dt>@T["Contacts.InternalNotes"]</dt>
                        <dd id="cdNoteCount">0</dd>
                    </div>
                </dl>
            </div>
        </div>
        <div class="modal-actions cd-actions">
            <button class="btn-ghost" type="button" onclick="closeContactDetailsModal()">@T["Action.Close"]</button>
            <a href="#" class="btn-primary-soft" id="cdOpenChat">@T["Contacts.OpenConversation"]</a>
        </div>
    </div>
</div>

@* ─── Confirmation modals ─── *@
<div class="modal-backdrop d-none" id="confirmModal" onclick="if(event.target===this) closeConfirmModal()">
    <div class="modal-panel modal-panel-small">
        <div class="modal-header">
            <h3 id="confirmTitle">@T["Common.Confirm.Title"]</h3>
            <button class="modal-close" type="button" onclick="closeConfirmModal()">✕</button>
        </div>
        <div class="modal-body">
            <p id="confirmBody" style="margin:0 0 8px;font-size:13.5px;color:#374151;"></p>
            <ul id="confirmList" class="disconnect-bullets"></ul>
        </div>
        <div class="modal-actions">
            <button class="btn-ghost" type="button" onclick="closeConfirmModal()">@T["Action.Cancel"]</button>
            <button class="btn-ghost btn-danger" type="button" id="confirmAction">@T["Common.Confirm.Action"]</button>
        </div>
    </div>
</div>

<div class="toast-stack" id="toastStack"></div>
@Html.AntiForgeryToken()

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    window.__TEAM__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(team.Select(u => new { id = u.Id, name = u.Name })));
    window.__CURRENT_USER_ID__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentUserId));
</script>
<script src="~/js/contacts.js" asp-append-version="true"></script>

</body>
</html>
