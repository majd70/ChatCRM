@model ForgotPasswordDto

@{
    ViewData["Title"] = "Reset password";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-copy">
            <span class="eyebrow">Account recovery</span>
            <h1>Reset your password</h1>
            <p>Enter your email and we’ll send a secure password reset link if your account is eligible.</p>
        </div>

        <form asp-action="ForgotPassword" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary text-danger"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control form-control-lg" autocomplete="email" placeholder="name@company.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-accent w-100 btn-lg">Send reset link</button>
        </form>

        <p class="auth-footer">Remembered your password? <a asp-action="Login" class="auth-link">Go back to sign in</a>.</p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
