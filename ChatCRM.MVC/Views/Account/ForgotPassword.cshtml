@model ForgotPasswordDto
@inject Microsoft.Extensions.Localization.IStringLocalizer T

@{
    ViewData["Title"] = T["Auth.Forgot.Title"].Value;
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-copy">
            <span class="eyebrow">@T["Auth.Forgot.Eyebrow"]</span>
            <h1>@T["Auth.Forgot.Heading"]</h1>
            <p>@T["Auth.Forgot.Sub"]</p>
        </div>

        <form asp-action="ForgotPassword" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary text-danger"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control form-control-lg" autocomplete="email" placeholder="name@company.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-accent w-100 btn-lg">@T["Auth.Forgot.Submit"]</button>
        </form>

        <p class="auth-footer">@T["Auth.Forgot.Footer"] <a asp-action="Login" class="auth-link">@T["Auth.Forgot.BackToSignIn"]</a>.</p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
