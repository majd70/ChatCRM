@model ResendConfirmationEmailDto
@inject Microsoft.Extensions.Localization.IStringLocalizer T

@{
    ViewData["Title"] = T["Auth.Verify.Title"].Value;
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-copy">
            <span class="eyebrow">@T["Auth.Verify.Eyebrow"]</span>
            <h1>@T["Auth.Verify.Heading"]</h1>
            <p>@T["Auth.Verify.SubBefore"] <strong>@Model.Email</strong>@T["Auth.Verify.SubAfter"]</p>
            <p class="form-hint mb-0">@Html.Raw(T["Auth.Verify.DevHint"].Value)</p>
        </div>

        <form asp-action="ResendConfirmationEmail" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary text-danger"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control form-control-lg" autocomplete="email" placeholder="name@company.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-outline-primary w-100 btn-lg">@T["Auth.Verify.Submit"]</button>
        </form>

        <p class="auth-footer">@T["Auth.Verify.Footer"] <a asp-action="Login" class="auth-link">@T["Auth.Verify.SignIn"]</a>.</p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
