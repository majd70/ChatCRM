@model RegisterDto
@inject Microsoft.Extensions.Localization.IStringLocalizer T

@{
    ViewData["Title"] = T["Auth.Register.Title"].Value;
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-copy">
            <span class="eyebrow">@T["Auth.Register.Eyebrow"]</span>
            <h1>@T["Auth.Register.Heading"]</h1>
            <p>@T["Auth.Register.Sub"]</p>
        </div>

        <form asp-action="Register" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary text-danger"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control form-control-lg" autocomplete="email" placeholder="name@company.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <div class="password-field">
                    <input asp-for="Password" class="form-control form-control-lg" autocomplete="new-password" placeholder="@T["Auth.Register.PasswordPlaceholder"]" />
                    <button type="button" class="password-toggle" data-password-toggle aria-label="@T["Auth.Login.ShowPassword"]" aria-pressed="false">
                        <span class="password-toggle-text">@T["Auth.Login.Show"]</span>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
                <div class="form-hint">@T["Auth.Register.PasswordHint"]</div>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <div class="password-field">
                    <input asp-for="ConfirmPassword" class="form-control form-control-lg" autocomplete="new-password" placeholder="@T["Auth.Register.ConfirmPlaceholder"]" />
                    <button type="button" class="password-toggle" data-password-toggle aria-label="@T["Auth.Login.ShowPassword"]" aria-pressed="false">
                        <span class="password-toggle-text">@T["Auth.Login.Show"]</span>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-accent w-100 btn-lg">@T["Auth.Register.Submit"]</button>
        </form>

        <p class="auth-footer">@T["Auth.Register.Footer"] <a asp-action="Login" class="auth-link">@T["Auth.Register.SignIn"]</a>.</p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
