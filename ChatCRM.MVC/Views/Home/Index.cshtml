@inject Microsoft.Extensions.Localization.IStringLocalizer T
@{
    ViewData["Title"] = T["Home.Title"].Value;
}

<section class="hero-panel">
    <div class="hero-copy">
        <span class="eyebrow">@T["Home.Eyebrow"]</span>
        <h1>@T["Home.Heading"]</h1>
        <p class="lead">@T["Home.Lead"]</p>
        <div class="hero-actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-accent" asp-controller="Home" asp-action="Privacy">@T["Home.ContinueApp"]</a>
            }
            else
            {
                <a class="btn btn-accent" asp-controller="Account" asp-action="Register">@T["Home.CreateAccount"]</a>
                <a class="btn btn-outline-light" asp-controller="Account" asp-action="Login">@T["Home.SignIn"]</a>
            }
        </div>
    </div>
    <div class="hero-card">
        <div class="mini-stat">
            <span class="mini-stat-label">@T["Home.Stat.ProtectionLabel"]</span>
            <strong>@T["Home.Stat.Protection"]</strong>
        </div>
        <div class="mini-stat">
            <span class="mini-stat-label">@T["Home.Stat.RecoveryLabel"]</span>
            <strong>@T["Home.Stat.Recovery"]</strong>
        </div>
        <div class="mini-stat">
            <span class="mini-stat-label">@T["Home.Stat.ExperienceLabel"]</span>
            <strong>@T["Home.Stat.Experience"]</strong>
        </div>
    </div>
</section>
