@model List<ChatCRM.Application.Chats.DTOs.InstanceDto>
@using ChatCRM.Domain.Entities
@{
    ViewData["Title"] = "WhatsApp Numbers";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WhatsApp Numbers — ChatCRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/instances.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/inbox.css" asp-append-version="true" />
</head>
<body class="inbox-shell">

@await Html.PartialAsync("_DashboardRail", "numbers")

<main class="instances-page" style="flex:1; overflow-y:auto;">

    <div class="instances-header">
        <div>
            <h1 class="instances-title has-icon">
                @await Html.PartialAsync("_Icon", new IconModel("smartphone", size: 24))
                <span>WhatsApp Numbers</span>
            </h1>
            <p class="instances-sub">Connect and manage all your linked WhatsApp lines.</p>
        </div>
        <button class="btn-primary-round has-icon" onclick="openAddModal()">
            @await Html.PartialAsync("_Icon", new IconModel("plus", size: 16))
            <span>Add Number</span>
        </button>
    </div>

    <div class="instances-grid" id="instancesGrid">
        @foreach (var inst in Model)
        {
            <div class="instance-card" data-id="@inst.Id" data-card-status="@inst.Status.ToString().ToLowerInvariant()" data-display-name="@inst.DisplayName">
                <div class="instance-card-head">
                    <span class="status-dot status-@inst.Status.ToString().ToLowerInvariant()" title="@inst.Status" data-status-dot></span>
                    <h3 class="instance-name">@inst.DisplayName</h3>
                </div>
                <div class="instance-phone" data-phone>
                    @(string.IsNullOrWhiteSpace(inst.PhoneNumber) ? "—" : "+" + inst.PhoneNumber)
                </div>
                <div class="instance-meta">
                    <span class="meta-pill status-pill-@inst.Status.ToString().ToLowerInvariant()" data-status-pill>@FormatStatus(inst.Status)</span>
                    <span class="meta-dim" data-last-connected="@(inst.LastConnectedAt?.ToString("o") ?? "")">
                        @if (inst.LastConnectedAt.HasValue)
                        { @($"Connected {Relative(inst.LastConnectedAt.Value)}") }
                        else
                        { @("Never connected") }
                    </span>
                </div>
                <div class="instance-stats">
                    <div><strong data-conv-count>@inst.ConversationCount</strong> <span>chats</span></div>
                    <div><strong data-unread-count>@inst.UnreadCount</strong> <span>unread</span></div>
                </div>
                <div class="instance-actions">
                    <a href="/dashboard/chats?instance=@inst.Id" class="btn-ghost action-when-connected">Open inbox</a>
                    <button class="btn-ghost has-icon action-when-pending" onclick="openQr(@inst.Id)">
                        @await Html.PartialAsync("_Icon", new IconModel("qr-code", size: 14))
                        <span>Show QR</span>
                    </button>
                    <button class="btn-ghost has-icon action-when-disconnected" onclick="openQr(@inst.Id)">
                        @await Html.PartialAsync("_Icon", new IconModel("refresh-cw", size: 14))
                        <span>Reconnect</span>
                    </button>
                    <button class="btn-ghost btn-danger action-when-connected" onclick="openDisconnect(@inst.Id, '@Html.Raw(Html.Encode(inst.DisplayName))')">Disconnect</button>
                    <button class="btn-ghost btn-danger action-when-pending" onclick="openDisconnect(@inst.Id, '@Html.Raw(Html.Encode(inst.DisplayName))')">Cancel</button>
                    <button class="btn-icon btn-icon-danger" title="Delete permanently" aria-label="Delete @inst.DisplayName" onclick="openDelete(@inst.Id, '@Html.Raw(Html.Encode(inst.DisplayName))')">
                        @await Html.PartialAsync("_Icon", new IconModel("trash", size: 16))
                    </button>
                </div>
            </div>
        }

        <div class="instance-card instance-card-add" onclick="openAddModal()">
            <div class="add-card-plus">＋</div>
            <div class="add-card-label">Add New Number</div>
        </div>
    </div>
</main>

<!-- ─── Add Number modal ───────────────────────────────────────────── -->
<div class="modal-backdrop d-none" id="addModal" onclick="if(event.target===this) closeAddModal()">
    <div class="modal-panel">
        <div class="modal-header">
            <h3 id="modalTitle">Add WhatsApp Number</h3>
            <button class="modal-close" onclick="closeAddModal()">✕</button>
        </div>

        <!-- Step 1 -->
        <div class="modal-step" id="step1">
            <label class="form-label" for="displayNameInput">Display name</label>
            <input type="text" id="displayNameInput" class="form-input" placeholder="e.g. Sales Line" maxlength="100" autocomplete="off" />
            <p class="form-hint">Shown in your dashboard sidebar.</p>

            <div class="form-error d-none" id="createError" role="alert"></div>

            <div class="modal-actions">
                <button class="btn-ghost" onclick="closeAddModal()" id="cancelCreateBtn">Cancel</button>
                <button class="btn-primary-round" onclick="submitCreate()" id="submitCreateBtn">
                    <span class="btn-label">Next →</span>
                    <span class="btn-spinner d-none" aria-hidden="true"></span>
                </button>
            </div>
        </div>

        <!-- Step 2 -->
        <div class="modal-step d-none" id="step2">
            <div class="qr-container">
                <div class="qr-box" id="qrBox">
                    <div class="spinner"></div>
                </div>
                <div class="qr-instructions">
                    <ol>
                        <li>Open <b>WhatsApp</b> on your phone</li>
                        <li>Tap <b>⋮ / Settings → Linked Devices</b></li>
                        <li>Tap <b>Link a Device</b></li>
                        <li>Scan the code on the left</li>
                    </ol>
                    <div class="waiting-indicator" id="waitingIndicator">
                        <span class="dot-pulse"></span> Waiting for scan…
                    </div>
                </div>
            </div>

            <div class="modal-actions">
                <button class="btn-ghost has-icon" onclick="refreshQr()">
                    @await Html.PartialAsync("_Icon", new IconModel("refresh-cw", size: 14))
                    <span>Refresh QR</span>
                </button>
                <button class="btn-ghost" onclick="closeAddModal()">Close</button>
            </div>
        </div>

        <!-- Step 3: success -->
        <div class="modal-step d-none" id="step3">
            <div class="success-card">
                <div class="success-icon">@await Html.PartialAsync("_Icon", new IconModel("check", size: 28))</div>
                <h3>Connected!</h3>
                <p id="successDetails">Your WhatsApp number is now linked.</p>
            </div>
            <div class="modal-actions">
                <button class="btn-primary-round" onclick="location.reload()">Done</button>
            </div>
        </div>
    </div>
</div>

<!-- ─── Disconnect confirmation ────────────────────────────────────── -->
<div class="modal-backdrop d-none" id="disconnectModal" onclick="if(event.target===this) closeDisconnect()">
    <div class="modal-panel modal-panel-small">
        <div class="modal-header">
            <h3>Disconnect <span id="disconnectName"></span>?</h3>
            <button class="modal-close" onclick="closeDisconnect()">✕</button>
        </div>
        <div class="modal-body">
            <ul class="disconnect-bullets">
                <li>The number will be unlinked from WhatsApp</li>
                <li>Conversation history stays saved</li>
                <li>No new messages will be received</li>
            </ul>
        </div>
        <div class="modal-actions">
            <button class="btn-ghost" onclick="closeDisconnect()">Cancel</button>
            <button class="btn-ghost btn-danger" onclick="confirmDisconnect()">Disconnect</button>
        </div>
    </div>
</div>

<!-- ─── Delete confirmation (permanent) ────────────────────────────── -->
<div class="modal-backdrop d-none" id="deleteModal" onclick="if(event.target===this) closeDelete()">
    <div class="modal-panel modal-panel-small">
        <div class="modal-header">
            <h3>Delete <span id="deleteName"></span> permanently?</h3>
            <button class="modal-close" onclick="closeDelete()">✕</button>
        </div>
        <div class="modal-body">
            <ul class="disconnect-bullets">
                <li><strong>All conversations and messages</strong> for this number will be deleted</li>
                <li>The number will be unlinked from WhatsApp</li>
                <li>The Evolution API instance will be deleted</li>
                <li class="text-danger"><strong>This cannot be undone.</strong></li>
            </ul>
            <label class="form-label" style="margin-top:14px;">Type <code>DELETE</code> to confirm:</label>
            <input type="text" id="deleteConfirmInput" class="form-input" oninput="updateDeleteButton()" autocomplete="off" />
        </div>
        <div class="modal-actions">
            <button class="btn-ghost" onclick="closeDelete()">Cancel</button>
            <button class="btn-ghost btn-danger" id="deleteConfirmBtn" onclick="confirmDelete()" disabled>Delete forever</button>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script src="~/js/instances.js" asp-append-version="true"></script>

</body>
</html>

@functions {
    static string FormatStatus(InstanceStatus s) => s switch
    {
        InstanceStatus.Connected => "Connected",
        InstanceStatus.Connecting => "Connecting",
        InstanceStatus.Pending => "Awaiting QR scan",
        InstanceStatus.Disconnected => "Disconnected",
        _ => s.ToString()
    };

    static string Relative(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes} min ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours} hr ago";
        return $"{(int)diff.TotalDays} days ago";
    }
}
