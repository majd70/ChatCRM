@using System.Globalization
@inject Microsoft.Extensions.Localization.IStringLocalizer T
@inject ChatCRM.MVC.Localization.JsonStringLocalizer.ResourceCache LocalizationCache
@{
    ViewData["Title"] = T["Channels.Title"].Value;
    Layout = null;
    var whatsappCount = (int?)ViewBag.WhatsAppCount ?? 0;

    var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var translations = LocalizationCache.Load(culture) ?? LocalizationCache.Load("en") ?? new Dictionary<string, string>();
    var translationsJson = System.Text.Json.JsonSerializer.Serialize(translations);
    var htmlLang = culture;
    var htmlDir = (culture is "ar" or "he" or "fa" or "ur") ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@htmlLang" dir="@htmlDir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@T["Channels.Title"] — ChatCRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/instances.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/inbox.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/settings.css" asp-append-version="true" />
    <script>
        window.__i18n__ = @Html.Raw(translationsJson);
        window.__i18nCulture__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(culture));
    </script>
    <script src="~/js/i18n.js" asp-append-version="true"></script>
</head>
<body class="inbox-shell">

@await Html.PartialAsync("_DashboardRail", "settings")

<div class="settings-layout">

    @await Html.PartialAsync("_SettingsSidenav", "channels")

    @* ─── Main content ─── *@
    <main class="settings-main">

        <div class="settings-header">
            <h1 class="settings-title">@T["Channels.Title"]</h1>
            <p class="settings-sub">@T["Channels.Subtitle"]</p>
        </div>

        <div class="channel-grid">

            @* WhatsApp — active *@
            <a href="/dashboard/whatsapp" class="channel-card channel-card-active">
                <div class="channel-card-head">
                    <span class="channel-icon channel-icon-whatsapp">
                        @await Html.PartialAsync("_Icon", new IconModel("channel-whatsapp", size: 26))
                    </span>
                    <span class="channel-status-pill channel-status-active">
                        @await Html.PartialAsync("_Icon", new IconModel("check", size: 11))
                        <span>@T["Channels.Status.Active"]</span>
                    </span>
                </div>
                <h3 class="channel-name">WhatsApp</h3>
                <p class="channel-desc">@T["Channels.WhatsApp.Desc"]</p>
                <div class="channel-card-foot">
                    <strong>@whatsappCount</strong>&nbsp;<span>@(whatsappCount == 1 ? T["Channels.ConnectedNumbersOne"].Value : T["Channels.ConnectedNumbersMany"].Value)</span>
                    <span class="channel-action">@T["Channels.Manage"]</span>
                </div>
            </a>

            @* Instagram — coming soon *@
            <div class="channel-card channel-card-disabled" aria-disabled="true">
                <div class="channel-card-head">
                    <span class="channel-icon channel-icon-instagram">
                        @await Html.PartialAsync("_Icon", new IconModel("channel-instagram", size: 26))
                    </span>
                    <span class="channel-status-pill channel-status-soon">@T["Channels.Status.ComingSoon"]</span>
                </div>
                <h3 class="channel-name">@T["Channels.Instagram.Name"]</h3>
                <p class="channel-desc">@T["Channels.Instagram.Desc"]</p>
                <div class="channel-card-foot">
                    <span class="channel-foot-muted">@T["Channels.NotAvailable"]</span>
                </div>
            </div>

            @* Messenger — coming soon *@
            <div class="channel-card channel-card-disabled" aria-disabled="true">
                <div class="channel-card-head">
                    <span class="channel-icon channel-icon-messenger">
                        @await Html.PartialAsync("_Icon", new IconModel("channel-messenger", size: 26))
                    </span>
                    <span class="channel-status-pill channel-status-soon">@T["Channels.Status.ComingSoon"]</span>
                </div>
                <h3 class="channel-name">@T["Channels.Messenger.Name"]</h3>
                <p class="channel-desc">@T["Channels.Messenger.Desc"]</p>
                <div class="channel-card-foot">
                    <span class="channel-foot-muted">@T["Channels.NotAvailable"]</span>
                </div>
            </div>

        </div>
    </main>
</div>

</body>
</html>
