# Copy this file to `.env` in the same directory and replace the placeholders
# with real values before running `docker compose up -d`.
#
#   cp .env.example .env
#
# `.env` is gitignored so your real credentials never reach the repo.

# ── Evolution API ────────────────────────────────────────────────
# Pick any long random string. Clients (including ChatCRM) will need
# this same value in their `apikey` header.
AUTHENTICATION_API_KEY=replace-me-with-a-long-random-string

# ── PostgreSQL (used by Evolution to persist instance state) ────
POSTGRES_USER=evo_user
POSTGRES_PASSWORD=replace-me-with-a-strong-password
POSTGRES_DB=evolution
